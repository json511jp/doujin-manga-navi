# ============================================================
# 環境変数設定ファイル
# ============================================================
# このファイルをコピーして .env を作成し、各値を入力してください。
# $ cp .env.example .env
#
# ※ .env は絶対に Git にコミットしないでください。
#    .gitignore に .env が含まれていることを確認してください。
# ============================================================


# ------------------------------------------------------------
# Astro / Cloudflare Pages 用（公開キー）
# ------------------------------------------------------------
# SupabaseのプロジェクトURL
# 取得場所: Supabase ダッシュボード → Settings → API → Project URL
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase の anon キー（公開用・読み取り専用）
# 取得場所: Supabase ダッシュボード → Settings → API → anon public
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Analytics 4 測定ID（任意）
# 取得場所: GA4 管理画面 → データストリーム → 測定ID（G-XXXXXXXXXX）
PUBLIC_GA4_ID=G-XXXXXXXXXX


# ------------------------------------------------------------
# GitHub Actions Secrets 用（秘密キー・絶対に公開しない）
# ------------------------------------------------------------
# DMM アフィリエイト API ID
# 取得場所: https://affiliate.dmm.com/api/ → API利用申請
DMM_API_ID=your_api_id_here

# DMM アフィリエイト ID
# 取得場所: DMM アフィリエイト管理画面 → アフィリエイトID
DMM_AFFILIATE_ID=your_affiliate_id-990

# DMM API フロア設定（site.config.js の dmm 設定と合わせてください）
# デフォルト値（省略可）: FANZA / digital / videoa
# 例: ebook フロアにする場合 → DMM_SITE=FANZA DMM_SERVICE=ebook DMM_FLOOR=comic
DMM_SITE=FANZA
DMM_SERVICE=digital
DMM_FLOOR=videoa

# Supabase プロジェクトURL（GitHub Actions 用）
# PUBLIC_SUPABASE_URL と同じ値でOK
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase service_role キー（書き込み用・絶対に公開しない）
# 取得場所: Supabase ダッシュボード → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

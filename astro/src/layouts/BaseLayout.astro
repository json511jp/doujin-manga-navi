---
import '../styles/global.css';
import AgeGate from '../components/AgeGate.astro';
import { siteConfig } from '../../../site.config.js';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = siteConfig.siteDescription,
  ogImage,
  canonical,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const defaultOgImage = `${siteConfig.siteUrl}/og-default.jpg`;
const ogImageUrl = ogImage ?? defaultOgImage;
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
const themeVars = Astro.locals.themeVars ?? '';
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="rating" content="adult" />
  <meta name="RTA-label" content="RTA-5042-1996-1400-1577-RTA" />
  {themeVars && <style set:html={`:root{${themeVars}}`} />}
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content={siteConfig.siteName} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />

  {/* GA4: 同意後にのみロード（gtag初期化はdefault denied状態） */}
  {ga4Id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
      <script define:vars={{ ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        // デフォルトは拒否状態（同意前はデータ送信しない）
        gtag('consent', 'default', {
          analytics_storage: 'denied',
          ad_storage: 'denied',
          wait_for_update: 2000,
        });
        gtag('config', ga4Id, { send_page_view: false });
        window.__ga4Id = ga4Id;
      </script>
    </>
  )}

  <slot name="head" />
</head>
<body style={`background:${siteConfig.colors.background};color:#f0f0f0;min-height:100dvh;`}>
  <AgeGate />
  <slot />

  {/* Cookie同意バナー */}
  <div id="cookieBanner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:200;padding:0 0 8px;">
    <div style="background:rgba(17,17,17,0.97);border-top:1px solid #2a2a2a;padding:16px;max-width:600px;margin:0 auto;border-radius:12px 12px 0 0;backdrop-filter:blur(8px);">
      <p style="font-size:12px;color:#aaa;line-height:1.7;margin-bottom:12px;">
        当サイトはアクセス解析（Google Analytics 4）にCookieを使用しています。
        詳細は<a href="/privacy" style="color:#d4a843;text-decoration:underline;">プライバシーポリシー</a>をご覧ください。
      </p>
      <div style="display:flex;gap:10px;justify-content:flex-end;">
        <button id="cookieDecline" style="background:none;border:1px solid #2a2a2a;color:#888;font-size:12px;padding:8px 16px;border-radius:8px;cursor:pointer;font-family:inherit;">拒否</button>
        <button id="cookieAccept" style={`background:${siteConfig.colors.accent};border:none;color:#000;font-size:12px;font-weight:700;padding:8px 16px;border-radius:8px;cursor:pointer;font-family:inherit;`}>同意する</button>
      </div>
    </div>
  </div>

  <script>
    const CONSENT_KEY = 'analytics_consent';

    function getConsent() {
      return document.cookie.split('; ').find(r => r.startsWith(CONSENT_KEY + '='))?.split('=')[1];
    }

    function setConsent(value: 'granted' | 'denied') {
      const expires = new Date(Date.now() + 365 * 864e5).toUTCString();
      document.cookie = `${CONSENT_KEY}=${value};expires=${expires};path=/;SameSite=Lax;Secure`;
    }

    function applyConsent(value: 'granted' | 'denied') {
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('consent', 'update', {
          analytics_storage: value,
          ad_storage: 'denied',
        });
        if (value === 'granted' && (window as any).__ga4Id) {
          (window as any).gtag('config', (window as any).__ga4Id, {
            page_path: window.location.pathname,
          });
        }
      }
    }

    const consent = getConsent();
    const banner = document.getElementById('cookieBanner');

    if (consent === 'granted') {
      applyConsent('granted');
    } else if (consent === 'denied') {
      // 拒否済み — バナー非表示のまま
    } else {
      // 未選択 — バナー表示
      if (banner) banner.style.display = 'block';
    }

    document.getElementById('cookieAccept')?.addEventListener('click', () => {
      setConsent('granted');
      applyConsent('granted');
      if (banner) banner.style.display = 'none';
    });

    document.getElementById('cookieDecline')?.addEventListener('click', () => {
      setConsent('denied');
      if (banner) banner.style.display = 'none';
    });
  </script>

  <footer style="padding:24px 16px 80px;border-top:1px solid #1a1a1a;text-align:center;">
    <p style="font-size:11px;color:#555;line-height:1.8;max-width:600px;margin:0 auto 16px;">
      本サイトは{siteConfig.affiliate.programName}に参加しており、掲載リンクを経由してご購入いただいた場合に紹介料を受け取ることがあります（<strong style="color:#666;">PR</strong>）。<br />
      掲載価格はすべて税込表示です。配信状況・価格・在庫は予告なく変更される場合があります。正確な情報は各作品の配信ページでご確認ください。<br />
      {siteConfig.affiliate.ageRestricted && <>本サイトは18歳以上の方を対象としています。<br /></>}
      <a href="/about" style="color:#555;text-decoration:underline;">このサイトについて</a>
      ／ <a href="/privacy" style="color:#555;text-decoration:underline;">プライバシーポリシー</a>
      ／ <a href={`/contact`} style="color:#555;text-decoration:underline;">お問い合わせ</a>
    </p>
    <div>
      <a href="https://affiliate.dmm.com/api/"><img src="https://p.dmm.co.jp/p/affiliate/web_service/r18_135_17.gif" width="135" height="17" alt="WEB SERVICE BY FANZA" /></a>
    </div>
  </footer>
</body>
</html>

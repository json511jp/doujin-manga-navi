---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BottomNav from '../components/BottomNav.astro';
import ProductCard from '../components/ProductCard.astro';
import { supabase } from '../lib/supabase';
const s = Astro.locals.siteSettings;

// Fetch moods
const { data: moods } = await supabase
  .from('moods')
  .select('id, name, slug')
  .limit(4);

// Fetch monthly ranking (top 5)
const { data: rankingsRaw } = await supabase
  .from('rankings')
  .select(`
    rank_position,
    products (
      id, dmm_content_id, title, image_url_small, review_average, review_count, price_min, price_text
    )
  `)
  .eq('rank_type', 'monthly')
  .order('rank_position', { ascending: true })
  .limit(5);
type RankingRow = { rank_position: number; products: { id: string; dmm_content_id: string; title: string; image_url_small: string | null; review_average: number | null; review_count: number | null; price_min: number | null; price_text: string | null } | null };
const rankings = rankingsRaw as RankingRow[] | null;

// Fetch featured actresses (ordered by appearance count)
const { data: paRows } = await supabase
  .from('product_actresses')
  .select('actress_id')
  .limit(5000);

type ActressRow = { id: string; name: string; slug: string; image_url_small: string | null };
let actresses: ActressRow[] | null = null;
if (paRows && paRows.length > 0) {
  const counts = new Map<string, number>();
  for (const row of paRows) counts.set(row.actress_id, (counts.get(row.actress_id) ?? 0) + 1);
  const topIds = [...counts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 6).map(([id]) => id);
  const { data } = await supabase
    .from('actresses')
    .select('id, name, slug, image_url_small')
    .in('id', topIds);
  // restore sort order by count
  const detailMap = new Map((data ?? []).map((a: any) => [a.id, a]));
  actresses = topIds.map(id => detailMap.get(id)).filter(Boolean) as ActressRow[];
}

// Fetch new arrivals
const { data: newProductsRaw } = await supabase
  .from('products')
  .select('id, dmm_content_id, title, image_url_small, image_url_large, review_average, review_count, price_min, price_text, release_date')
  .eq('is_active', true)
  .order('release_date', { ascending: false })
  .limit(8);
type ProductRow = { id: string; dmm_content_id: string; title: string; image_url_small: string | null; image_url_large: string | null; review_average: number | null; review_count: number | null; price_min: number | null; price_text: string | null; release_date: string | null };
const newProducts = newProductsRaw as ProductRow[] | null;

const rankBadgeColor = (pos: number) => {
  if (pos === 1) return '#d4a843';
  if (pos === 2) return '#888';
  return '#a05c3b';
};
---

<BaseLayout title={`${s.tagline} | ${s.siteName}`}>
  <Header />

  <main style="max-width:1024px;margin:0 auto;padding-bottom:80px;">
<!-- Genre Tags -->
<section style="padding:16px 16px 0;">
  <h2 style="font-size:18px;font-weight:700;margin-bottom:12px;">ジャンルから探す</h2>
  <div style="display:flex;flex-wrap:wrap;gap:8px;">
    <a href="/tag/1039" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">人妻・主婦</a>
    <a href="/tag/1014" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">熟女</a>
    <a href="/tag/2001" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">巨乳</a>
    <a href="/tag/4111" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">寝取り・NTR</a>
    <a href="/tag/5001" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">中出し</a>
    <a href="/tag/1027" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">美少女</a>
    <a href="/tag/5060" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">母乳</a>
    <a href="/tag/160018" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">妊娠・孕ませ</a>
    <a href="/tag/62" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">触手</a>
    <a href="/tag/160082" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">魔法少女</a>
    <a href="/tag/55" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">処女</a>
    <a href="/tag/4002" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">近親相姦</a>
    <a href="/tag/5010" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">監禁</a>
    <a href="/tag/153030" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">百合</a>
    <a href="/tag/160146" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">快楽堕ち</a>
    <a href="/tag/160063" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">洗脳</a>
    <a href="/tag/160010" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">キス</a>
    <a href="/tag/153003" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">おっぱい</a>
    <a href="/tag/160038" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">鬼畜</a>
    <a href="/tag/27" style="background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.3);color:#d4a843;font-size:13px;font-weight:500;padding:6px 12px;border-radius:6px;text-decoration:none;">辱め</a>
  </div>
</section>
    <!-- Mood UI -->
    <section style="padding:24px 16px 16px;">
      <h2 style="font-size:18px;font-weight:700;margin-bottom:16px;">今日の気分は？</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        {(moods && moods.length > 0 ? moods : [
          { slug: 'haitoku', name: '背徳感が欲しい' },
          { slug: 'ochiru', name: 'じっくり堕ちていく' },
          { slug: 'jukujo', name: '熟女が好き' },
          { slug: 'shinsaku', name: '新作を見たい' },
        ]).map(mood => (
          <a
            href={`/explore/${mood.slug}`}
            style="border:1px solid #2a2a2a;background:#111;border-radius:12px;padding:16px;text-decoration:none;color:#f0f0f0;transition:border-color 0.2s,background 0.2s,color 0.2s;"
            onmouseover="this.style.borderColor='#d4a843';this.style.background='#1a1a1a';this.style.color='#d4a843'"
            onmouseout="this.style.borderColor='#2a2a2a';this.style.background='#111';this.style.color='#f0f0f0'"
          >
            <div style="font-size:15px;font-weight:600;">{mood.name}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Like CTA -->
    <section style="padding:0 16px 16px;">
      <a href="/ranking/likes" style="display:flex;align-items:center;gap:12px;background:rgba(212,168,67,0.06);border:1px solid rgba(212,168,67,0.25);border-radius:12px;padding:14px 16px;text-decoration:none;color:inherit;">
        <span style="font-size:28px;line-height:1;">❤️</span>
        <div>
          <div style="font-size:14px;font-weight:700;color:#f0f0f0;">気に入った作品に「いいね」しよう</div>
          <div style="font-size:12px;color:#888;margin-top:2px;">作品・女優ページで押せます。いいねランキングも見られます →</div>
        </div>
      </a>
    </section>

    <!-- Monthly Ranking -->
    {rankings && rankings.length > 0 && (
      <section style="padding:8px 16px 16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <h2 style="font-size:18px;font-weight:700;">月間ランキング</h2>
          <a href="/ranking/monthly" style="font-size:13px;color:#888;text-decoration:none;">もっと見る →</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {rankings.map(r => {
            const p = r.products as any;
            if (!p) return null;
            return (
              <a href={`/item/${p.dmm_content_id}`} style="display:flex;align-items:center;gap:12px;background:#111;border:1px solid #2a2a2a;border-radius:12px;padding:12px;text-decoration:none;color:inherit;">
                <div style={`background:${rankBadgeColor(r.rank_position)};color:#000;font-weight:700;font-size:12px;width:24px;height:24px;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>{r.rank_position}</div>
                <div style="width:64px;height:90px;border-radius:6px;overflow:hidden;flex-shrink:0;background:#1a1a1a;">
                  {p.image_url_small && <img src={p.image_url_small} alt={p.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />}
                </div>
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13px;font-weight:600;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{p.title}</div>
                  <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
                    {p.review_average != null && p.review_average > 0 && <span style="color:#d4a843;font-size:13px;font-weight:600;">★ {Number(p.review_average).toFixed(1)}</span>}
                    {p.review_count != null && p.review_count > 0 && <span style="font-size:12px;color:#888;">({p.review_count})</span>}
                    {(p.price_text || p.price_min) && <span style="font-size:13px;font-weight:600;margin-left:auto;">{p.price_text ?? `¥${p.price_min.toLocaleString()}〜`}</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Featured Actresses -->
    {actresses && actresses.length > 0 && (
      <section style="padding:8px 16px 16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <h2 style="font-size:18px;font-weight:700;">注目の女優</h2>
          <a href="/actress" style="font-size:13px;color:#888;text-decoration:none;">一覧 →</a>
        </div>
        <div style="display:flex;gap:12px;overflow-x:auto;padding-bottom:8px;scrollbar-width:none;">
          {actresses.map(a => (
            <a href={`/actress/${a.slug}`} style="flex-shrink:0;width:88px;text-align:center;text-decoration:none;color:inherit;">
              <div style="width:72px;height:72px;border-radius:50%;background:#1a1a1a;margin:0 auto 6px;border:2px solid #2a2a2a;overflow:hidden;display:flex;align-items:center;justify-content:center;">
                {a.image_url_small
                  ? <img src={a.image_url_small} alt={a.name} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                  : <svg width="28" height="28" fill="none" stroke="#555" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                }
              </div>
              <div style="font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{a.name}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- New Arrivals -->
    {newProducts && newProducts.length > 0 && (
      <section style="padding:8px 16px 16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <h2 style="font-size:18px;font-weight:700;">新着作品</h2>
          <a href="/products" style="font-size:13px;color:#888;text-decoration:none;">もっと見る →</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {newProducts.map(p => (
            <a href={`/item/${p.dmm_content_id}`} style="display:flex;align-items:center;gap:12px;background:#111;border:1px solid #2a2a2a;border-radius:12px;padding:12px;text-decoration:none;color:inherit;">
              <div style="width:64px;height:90px;border-radius:6px;overflow:hidden;flex-shrink:0;background:#1a1a1a;">
                {p.image_url_small && <img src={p.image_url_small} alt={p.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />}
              </div>
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;font-weight:600;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{p.title}</div>
                <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
                  {p.review_average != null && p.review_average > 0 && <span style="color:#d4a843;font-size:13px;font-weight:600;">★ {Number(p.review_average).toFixed(1)}</span>}
                  {p.review_count != null && p.review_count > 0 && <span style="font-size:12px;color:#888;">({p.review_count})</span>}
                  {(p.price_text || p.price_min) && <span style="font-size:13px;font-weight:600;margin-left:auto;">{p.price_text ?? `¥${p.price_min!.toLocaleString()}〜`}</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
        <a href="/products" style="display:block;text-align:center;margin-top:16px;padding:12px;border:1px solid #2a2a2a;border-radius:10px;color:#888;text-decoration:none;font-size:14px;">
          全作品を見る →
        </a>
      </section>
    )}

  </main>

  <BottomNav active="top" />
</BaseLayout>

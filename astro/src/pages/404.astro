---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BottomNav from '../components/BottomNav.astro';
import { siteConfig } from '../../../site.config.js';
---

<BaseLayout
  title={`ページが見つかりません | ${siteConfig.siteName}`}
  description="お探しのページは見つかりませんでした。"
  noindex={true}
>
  <Header />

  <main style="min-height:60dvh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 24px;text-align:center;">
    <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-bottom:24px;opacity:0.4;">
      <path d="M32 50C32 50 12 37 12 23.5C12 17.15 17.15 12 23.5 12C27.1 12 30.3 13.7 32 16.4C33.7 13.7 36.9 12 40.5 12C46.85 12 52 17.15 52 23.5C52 37 32 50 32 50Z" fill="#d4a843"/>
    </svg>

    <p style="font-size:72px;font-weight:700;color:#2a2a2a;line-height:1;margin-bottom:8px;">404</p>
    <p style="font-size:16px;font-weight:600;color:#888;margin-bottom:8px;">ページが見つかりません</p>
    <p style="font-size:13px;color:#555;line-height:1.8;margin-bottom:32px;">
      お探しのページは削除されたか、URLが変更された可能性があります。
    </p>

    <div style="display:flex;flex-direction:column;gap:12px;width:100%;max-width:280px;">
      <a href="/" style="background:#d4a843;color:#000;font-weight:700;font-size:14px;padding:14px 24px;border-radius:10px;text-decoration:none;">
        トップへ戻る
      </a>
      <a href="/products" style="background:#111;border:1px solid #2a2a2a;color:#aaa;font-size:14px;padding:14px 24px;border-radius:10px;text-decoration:none;">
        全作品を見る
      </a>
    </div>
  </main>

  <BottomNav />
</BaseLayout>

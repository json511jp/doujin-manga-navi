---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BottomNav from '../../components/BottomNav.astro';
import { supabase } from '../../lib/supabase';
import { siteConfig } from '../../../../site.config.js';

const { type } = Astro.params;
const validTypes = ['monthly', 'weekly', 'ntr', 'likes'] as const;
type RankType = typeof validTypes[number];

if (!validTypes.includes(type as RankType)) return Astro.redirect('/ranking/monthly');

const labels: Record<RankType, string> = {
  monthly: '月間',
  weekly:  '週間',
  ntr:     'NTR',
  likes:   'いいね',
};
const label = labels[type as RankType];

type ProductData = {
  id: string; dmm_content_id: string; title: string;
  image_url_small: string | null; review_average: number | null;
  review_count: number | null; price_min: number | null; price_text: string | null;
  product_actresses: { actresses: { name: string } | null }[];
};
type RankRow = { rank_position: number; products: ProductData | null };

let rankings: RankRow[] = [];

if (type === 'likes') {
  // いいねランキング: likes テーブルを集計して上位50件
  const { data: likeRows } = await supabase
    .from('likes')
    .select('target_id')
    .eq('target_type', 'product');

  const counts = new Map<string, number>();
  for (const row of likeRows ?? []) {
    counts.set(row.target_id, (counts.get(row.target_id) ?? 0) + 1);
  }
  const topIds = [...counts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 50).map(([id]) => id);

  if (topIds.length > 0) {
    const { data: products } = await supabase
      .from('products')
      .select('id, dmm_content_id, title, image_url_small, review_average, review_count, price_min, price_text, product_actresses ( actresses ( name ) )')
      .in('id', topIds);
    const productMap = new Map((products ?? []).map((p: any) => [p.id, p]));
    rankings = topIds.map((id, i) => ({
      rank_position: i + 1,
      products: (productMap.get(id) as ProductData) ?? null,
    }));
  }
} else {
  const { data: rankingsRaw } = await supabase
    .from('rankings')
    .select(`
      rank_position,
      products ( id, dmm_content_id, title, image_url_small, review_average, review_count, price_min, price_text,
        product_actresses ( actresses ( name ) )
      )
    `)
    .eq('rank_type', type!)
    .order('rank_position', { ascending: true })
    .limit(100);
  rankings = (rankingsRaw ?? []) as RankRow[];
}

const badgeColor = (pos: number) => {
  if (pos === 1) return '#d4a843';
  if (pos === 2) return '#888';
  if (pos === 3) return '#a05c3b';
  return '#2a2a2a';
};
const badgeTextColor = (pos: number) => pos <= 3 ? '#000' : '#888';
---

<BaseLayout
  title={`${label}ランキング TOP${rankings.length} | ${siteConfig.siteName}`}
  description={`${siteConfig.siteName}の${label}ランキング。今一番人気の作品をチェック。`}
  canonical={`${siteConfig.siteUrl}/ranking/${type}`}
>
  <Header />

  <nav style="padding:10px 16px;font-size:12px;color:#555;max-width:1024px;margin:0 auto;">
    <a href="/" style="color:#555;text-decoration:none;">TOP</a>
    <span style="margin:0 6px;">›</span>
    <span style="color:#888;">{label}ランキング</span>
  </nav>

  <main style="max-width:1024px;margin:0 auto;padding:0 16px 100px;">

    <!-- Tab -->
    <div style="display:flex;gap:6px;margin-bottom:20px;flex-wrap:wrap;">
      {validTypes.map(t => (
        <a
          href={`/ranking/${t}`}
          style={`flex:1;min-width:60px;text-align:center;padding:10px 6px;border-radius:8px;text-decoration:none;font-size:12px;font-weight:600;border:1px solid ${t === type ? '#d4a843' : '#2a2a2a'};background:${t === type ? 'rgba(212,168,67,0.1)' : '#111'};color:${t === type ? '#d4a843' : '#888'};white-space:nowrap;`}
        >{t === 'likes' ? '❤️ ' : ''}{labels[t]}</a>
      ))}
    </div>

    <h1 style="font-size:20px;font-weight:700;margin-bottom:16px;">{type === 'likes' ? '❤️ ' : ''}{label}ランキング TOP{rankings.length}</h1>

    {rankings.length > 0 ? (
      <div style="display:flex;flex-direction:column;gap:10px;">
        {rankings.map(r => {
          const p = r.products;
          if (!p) return null;
          const price = p.price_text ?? (p.price_min ? `¥${p.price_min.toLocaleString()}〜` : null);
          const actressName = (p.product_actresses as any[])?.[0]?.actresses?.name ?? null;
          return (
            <a
              href={`/item/${p.dmm_content_id}`}
              style="display:flex;align-items:center;gap:12px;background:#111;border:1px solid #2a2a2a;border-radius:12px;padding:12px;text-decoration:none;color:inherit;transition:background 0.2s;"
              onmouseover="this.style.background='#1a1a1a'"
              onmouseout="this.style.background='#111'"
            >
              <div style={`background:${badgeColor(r.rank_position)};color:${badgeTextColor(r.rank_position)};font-weight:700;font-size:13px;min-width:28px;height:28px;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
                {type === 'likes' ? '❤️' : r.rank_position}
              </div>
              <div style="width:64px;height:90px;border-radius:6px;overflow:hidden;flex-shrink:0;background:#1a1a1a;">
                {p.image_url_small && <img src={p.image_url_small} alt={p.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />}
              </div>
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;font-weight:600;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{p.title}</div>
                {actressName && <div style="font-size:12px;color:#888;margin-top:3px;">{actressName}</div>}
                <div style="display:flex;align-items:center;gap:8px;margin-top:6px;flex-wrap:wrap;">
                  {p.review_average != null && p.review_average > 0 && <span style="color:#d4a843;font-size:13px;font-weight:600;">★ {Number(p.review_average).toFixed(1)}</span>}
                  {p.review_count != null && p.review_count > 0 && <span style="font-size:12px;color:#888;">({p.review_count})</span>}
                  {price && <span style="font-size:13px;font-weight:600;margin-left:auto;">{price}</span>}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div style="text-align:center;padding:60px 0;color:#888;">
        <p>ランキングデータがまだありません</p>
      </div>
    )}

  </main>

  <BottomNav active="ranking" />
</BaseLayout>

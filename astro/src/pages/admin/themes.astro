---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { THEMES, getThemeById } from '../../lib/themes';
import { getAdminSetting, setAdminSetting } from '../../lib/adminClient';

const currentThemeId = (await getAdminSetting<string>('theme')) ?? 'dark-gold';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const themeId = String(form.get('themeId') ?? 'dark-gold');
  const theme = getThemeById(themeId);
  await Promise.all([
    setAdminSetting('theme', themeId),
    setAdminSetting('colors', theme.colors),
  ]);
  return Astro.redirect('/admin/themes?saved=1');
}
---

<AdminLayout title="テーマ" activeNav="themes">
  <p style="color:var(--admin-text-2);font-size:13px;margin-bottom:24px;max-width:680px;">
    プリセットを選ぶか、カスタムカラーで作成できます。変更は公開サイトに即時反映されます。
  </p>

  <form method="POST" id="themeForm">
    <input type="hidden" name="themeId" id="themeId" value={currentThemeId} />

    <div class="card-title" style="margin-bottom:12px;">プリセット</div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;margin-bottom:28px;">
      {THEMES.map(theme => (
        <div
          class={`theme-card ${theme.id === currentThemeId ? 'selected' : ''}`}
          data-id={theme.id}
          data-accent={theme.colors.accent}
          style={`border:1px solid ${theme.id === currentThemeId ? theme.colors.accent : 'var(--admin-border)'};border-radius:12px;overflow:hidden;cursor:pointer;transition:all 0.15s;background:var(--admin-surface);position:relative;`}
        >
          {theme.id === currentThemeId && (
            <div style={`position:absolute;top:10px;right:10px;width:22px;height:22px;border-radius:50%;background:${theme.colors.accent};color:#000;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;z-index:1;`}>✓</div>
          )}
          <div style={`background:${theme.colors.background};padding:18px;`}>
            <div style={`background:${theme.colors.surface};border-radius:8px;padding:14px;border:1px solid rgba(255,255,255,0.06);`}>
              <div style={`width:44px;height:6px;background:${theme.colors.accent};border-radius:3px;margin-bottom:10px;`}></div>
              <div style="width:100%;height:4px;background:rgba(255,255,255,0.15);border-radius:2px;margin-bottom:6px;"></div>
              <div style="width:75%;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;margin-bottom:14px;"></div>
              <div style={`display:inline-block;background:${theme.colors.accent};color:#000;font-size:10px;font-weight:700;padding:4px 12px;border-radius:6px;`}>Action</div>
            </div>
          </div>
          <div style="padding:12px 16px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--admin-border);">
            <span style="font-size:13px;font-weight:600;color:var(--admin-text);">{theme.name}</span>
            <div style="display:flex;gap:4px;">
              {[theme.colors.background, theme.colors.surface, theme.colors.accent].map(c => (
                <div style={`width:14px;height:14px;background:${c};border-radius:50%;border:1px solid var(--admin-border-2);`}></div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="card" style="margin-bottom:24px;">
      <div class="card-title">カスタムカラー</div>
      <div class="grid-2">
        {[
          ['Bg', '背景色', '#0a0a0a'],
          ['Surface', 'カード背景色', '#111111'],
          ['Accent', 'アクセントカラー', '#d4a843'],
          ['AccentHover', 'アクセント（ホバー）', '#f0c060'],
        ].map(([name, label, placeholder]) => (
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">{label}</label>
            <div style="display:flex;gap:8px;align-items:center;">
              <input type="color" id={`color${name}`} style="width:38px;height:38px;border:1px solid var(--admin-border);background:none;cursor:pointer;border-radius:8px;padding:2px;" />
              <input class="form-input" id={`color${name}Text`} placeholder={placeholder} style="flex:1;font-family:ui-monospace,Menlo,monospace;" />
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top:16px;">
        <button type="button" class="btn btn-ghost" onclick="applyCustom()">カスタムカラーを適用</button>
      </div>
    </div>

    <div style="display:flex;justify-content:flex-end;position:sticky;bottom:16px;">
      <button type="submit" class="btn btn-primary">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/></svg>
        テーマを保存
      </button>
    </div>
  </form>
</AdminLayout>

<style>
  .theme-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px -6px rgba(0,0,0,0.4); }
</style>

<script define:vars={{ THEMES, currentThemeId }}>
  function selectTheme(id, accentColor) {
    document.getElementById('themeId').value = id;
    document.querySelectorAll('.theme-card').forEach(el => {
      const isSelected = el.dataset.id === id;
      el.style.borderColor = isSelected ? accentColor : 'var(--admin-border)';
    });
  }
  window.selectTheme = selectTheme;

  document.querySelectorAll('.theme-card').forEach(el => {
    el.addEventListener('click', () => selectTheme(el.dataset.id, el.dataset.accent));
  });

  function applyCustom() {
    const bg          = document.getElementById('colorBgText').value || document.getElementById('colorBg').value;
    const surface     = document.getElementById('colorSurfaceText').value || document.getElementById('colorSurface').value;
    const accent      = document.getElementById('colorAccentText').value || document.getElementById('colorAccent').value;
    const accentHover = document.getElementById('colorAccentHoverText').value || document.getElementById('colorAccentHover').value;
    if (!bg || !surface || !accent || !accentHover) { alert('すべての色を入力してください'); return; }
    document.getElementById('themeId').value = `custom:${bg}:${surface}:${accent}:${accentHover}`;
    document.getElementById('themeForm').submit();
  }
  window.applyCustom = applyCustom;

  ['Bg', 'Surface', 'Accent', 'AccentHover'].forEach(name => {
    const picker = document.getElementById(`color${name}`);
    const text   = document.getElementById(`color${name}Text`);
    if (!picker || !text) return;
    picker.addEventListener('input', () => { text.value = picker.value; });
    text.addEventListener('input', () => { if (/^#[0-9a-fA-F]{6}$/.test(text.value)) picker.value = text.value; });
  });

  const current = THEMES.find(t => t.id === currentThemeId) ?? THEMES[0];
  if (current) {
    const map = { Bg: 'background', Surface: 'surface', Accent: 'accent', AccentHover: 'accentHover' };
    Object.entries(map).forEach(([name, key]) => {
      const val = current.colors[key];
      document.getElementById(`color${name}`).value = val;
      document.getElementById(`color${name}Text`).value = val;
    });
  }
</script>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BottomNav from '../../components/BottomNav.astro';
import ProductCard from '../../components/ProductCard.astro';
import { supabase } from '../../lib/supabase';
const s = Astro.locals.siteSettings;

const PER_PAGE = 48;
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'));
const offset = (page - 1) * PER_PAGE;
const sort = (Astro.url.searchParams.get('sort') ?? 'new') as 'new' | 'review';
const q = (Astro.url.searchParams.get('q') ?? '').trim();

const baseQuery = () => {
  const b = supabase.from('products')
    .select('id, dmm_content_id, title, image_url_large, image_url_small, review_average, review_count, price_min, price_text')
    .eq('is_active', true);
  return q ? b.ilike('title', `%${q}%`) : b;
};

const countQuery = () => {
  const b = supabase.from('products').select('*', { count: 'exact', head: true }).eq('is_active', true);
  return q ? b.ilike('title', `%${q}%`) : b;
};

const { count } = await countQuery();
const totalCount = count ?? 0;
const totalPages = Math.ceil(totalCount / PER_PAGE);

const query = baseQuery().range(offset, offset + PER_PAGE - 1);
if (sort === 'review') {
  query.order('review_average', { ascending: false, nullsFirst: false });
} else {
  query.order('release_date', { ascending: false, nullsFirst: false });
}

const { data: productsRaw } = await query;
type ProductRow = { id: string; dmm_content_id: string; title: string; image_url_large: string | null; image_url_small: string | null; review_average: number | null; review_count: number | null; price_min: number | null; price_text: string | null };
const products = (productsRaw ?? []) as ProductRow[];

const sortLabel = sort === 'review' ? 'レビュー評価順' : '新着順';
---

<BaseLayout
  title={`全作品一覧${page > 1 ? ` (${page}ページ目)` : ''} | ${s.siteName}`}
  description={`${s.siteName}の全作品${totalCount}本を${sortLabel}で掲載。`}
  canonical={`${s.siteUrl}/products${q ? `?q=${encodeURIComponent(q)}` : ''}`}
  noindex={page > 1}
>
  <Header />

  <nav style="padding:10px 16px;font-size:12px;color:#555;max-width:1024px;margin:0 auto;">
    <a href="/" style="color:#555;text-decoration:none;">TOP</a>
    <span style="margin:0 6px;">›</span>
    <span style="color:#888;">全作品一覧</span>
  </nav>

  <main style="max-width:1024px;margin:0 auto;padding:0 16px 100px;">

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <div>
        <h1 style="font-size:20px;font-weight:700;">{q ? `「${q}」の検索結果` : '全作品一覧'}</h1>
        <p style="font-size:13px;color:#888;margin-top:2px;">{totalCount.toLocaleString()}本{q && <a href="/products" style="margin-left:8px;color:#d4a843;font-size:12px;text-decoration:none;">× クリア</a>}</p>
      </div>
      {!q && <div style="display:flex;gap:6px;">
        <a
          href={`/products?sort=new${page > 1 ? `&page=${page}` : ''}`}
          style={`font-size:12px;padding:6px 12px;border-radius:6px;text-decoration:none;border:1px solid ${sort === 'new' ? '#d4a843' : '#2a2a2a'};background:${sort === 'new' ? 'rgba(212,168,67,0.1)' : '#111'};color:${sort === 'new' ? '#d4a843' : '#888'};`}
        >新着順</a>
        <a
          href={`/products?sort=review${page > 1 ? `&page=${page}` : ''}`}
          style={`font-size:12px;padding:6px 12px;border-radius:6px;text-decoration:none;border:1px solid ${sort === 'review' ? '#d4a843' : '#2a2a2a'};background:${sort === 'review' ? 'rgba(212,168,67,0.1)' : '#111'};color:${sort === 'review' ? '#d4a843' : '#888'};`}
        >評価順</a>
      </div>}
    </div>

    {products.length > 0 ? (
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
        {products.map(p => (
          <a href={`/item/${p.dmm_content_id}`} style="display:flex;align-items:center;gap:12px;background:#111;border:1px solid #2a2a2a;border-radius:12px;padding:12px;text-decoration:none;color:inherit;">
            <div style="width:64px;height:90px;border-radius:6px;overflow:hidden;flex-shrink:0;background:#1a1a1a;">
              {p.image_url_small && <img src={p.image_url_small} alt={p.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />}
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;font-weight:600;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{p.title}</div>
              <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
                {p.review_average != null && p.review_average > 0 && <span style="color:#d4a843;font-size:13px;font-weight:600;">★ {Number(p.review_average).toFixed(1)}</span>}
                {p.review_count != null && p.review_count > 0 && <span style="font-size:12px;color:#888;">({p.review_count})</span>}
                {(p.price_text || p.price_min) && <span style="font-size:13px;font-weight:600;margin-left:auto;">{p.price_text ?? `¥${p.price_min!.toLocaleString()}〜`}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="text-align:center;padding:60px 0;color:#888;">作品が見つかりませんでした</div>
    )}

    {totalPages > 1 && (
      <div style="display:flex;justify-content:center;align-items:center;gap:8px;padding:16px 0;">
        {page > 1 && (
          <a href={`/products?sort=${sort}&page=${page - 1}`} style="padding:8px 16px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:13px;">← 前へ</a>
        )}
        <span style="font-size:13px;color:#888;">{page} / {totalPages}</span>
        {page < totalPages && (
          <a href={`/products?sort=${sort}&page=${page + 1}`} style="padding:8px 16px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:13px;">次へ →</a>
        )}
      </div>
    )}

  </main>

  <BottomNav />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BottomNav from '../../components/BottomNav.astro';
import { supabase } from '../../lib/supabase';

const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'));
const PER_PAGE = 48;
const offset = (page - 1) * PER_PAGE;

// 作品データがある女優のIDのみ取得
const { data: paRows } = await supabase
  .from('product_actresses')
  .select('actress_id');
const activeIds = [...new Set((paRows ?? []).map((r: any) => r.actress_id))];

const totalCount = activeIds.length;
const totalPages = Math.ceil(totalCount / PER_PAGE);
const pageIds = activeIds.slice(offset, offset + PER_PAGE);

const { data: actressesRaw } = pageIds.length > 0
  ? await supabase
      .from('actresses')
      .select('id, name, ruby, slug, image_url_small, bust, cup, height')
      .in('id', pageIds)
  : { data: [] };

type ActressRow = { id: string; name: string; ruby: string | null; slug: string; image_url_small: string | null; bust: number | null; cup: string | null; height: number | null };
const actresses = (actressesRaw ?? []) as unknown as ActressRow[];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'TOP', item: 'https://ntr-douga.com/' },
    { '@type': 'ListItem', position: 2, name: '女優一覧' },
  ],
};
---

<BaseLayout
  title={`人妻・NTR 女優一覧${page > 1 ? ` (${page}ページ目)` : ''} | NTR動画ナビ`}
  description={`人妻・NTR動画に出演する女優${totalCount}人を一覧で紹介。名前・スペック・出演作品をチェックできます。`}
  canonical="https://ntr-douga.com/actress"
  noindex={page > 1}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <Header />

  <nav style="padding:10px 16px;font-size:12px;color:#555;max-width:1024px;margin:0 auto;">
    <a href="/" style="color:#555;text-decoration:none;">TOP</a>
    <span style="margin:0 6px;">›</span>
    <span style="color:#888;">女優一覧</span>
  </nav>

  <main style="max-width:1024px;margin:0 auto;padding:0 16px 100px;">
    <h1 style="font-size:20px;font-weight:700;margin-bottom:4px;">人妻・NTR 女優一覧</h1>
    <p style="font-size:13px;color:#888;margin-bottom:20px;">{totalCount}人</p>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:32px;">
      {actresses.map(a => (
        <a href={`/actress/${a.slug}`} style="text-decoration:none;color:inherit;background:#111;border:1px solid #2a2a2a;border-radius:10px;padding:12px 8px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:6px;">
          <div style="width:64px;height:64px;border-radius:50%;border:2px solid #d4a843;overflow:hidden;background:#1a1a1a;flex-shrink:0;">
            {a.image_url_small
              ? <img src={a.image_url_small} alt={a.name} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
              : <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a1a1a,#2a2a2a);display:flex;align-items:center;justify-content:center;">
                  <svg width="24" height="24" fill="none" stroke="#555" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
            }
          </div>
          <div style="font-size:12px;font-weight:600;line-height:1.3;word-break:break-all;">{a.name}</div>
          {a.ruby && <div style="font-size:10px;color:#666;">{a.ruby}</div>}
          {(a.bust || a.cup || a.height) && (
            <div style="font-size:10px;color:#555;">
              {a.bust ? `B${a.bust}${a.cup ?? ''}` : ''}{a.height ? ` ${a.height}cm` : ''}
            </div>
          )}
        </a>
      ))}
    </div>

    {totalPages > 1 && (
      <div style="display:flex;justify-content:center;gap:12px;margin-top:8px;">
        {page > 1 && <a href={`/actress?page=${page - 1}`} style="padding:10px 20px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:14px;">← 前へ</a>}
        <span style="padding:10px 16px;color:#555;font-size:14px;">{page} / {totalPages}</span>
        {page < totalPages && <a href={`/actress?page=${page + 1}`} style="padding:10px 20px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:14px;">次へ →</a>}
      </div>
    )}
  </main>

  <BottomNav active="actress" />
</BaseLayout>

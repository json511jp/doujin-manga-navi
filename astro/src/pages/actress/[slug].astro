---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BottomNav from '../../components/BottomNav.astro';
import ProductCard from '../../components/ProductCard.astro';
import LikeButton from '../../components/LikeButton.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;

const { data: actress } = await supabase
  .from('actresses')
  .select('*')
  .eq('slug', slug!)
  .single();

if (!actress) return Astro.redirect('/404');
type ActressDetail = { id: string; name: string; ruby: string | null; slug: string; bust: number | null; cup: string | null; waist: number | null; hip: number | null; height: number | null; image_url_small: string | null; image_url_large: string | null };
const a = actress as unknown as ActressDetail;

const PER_PAGE = 24;
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'));
const offset = (page - 1) * PER_PAGE;

const { count } = await supabase
  .from('product_actresses')
  .select('*', { count: 'exact', head: true })
  .eq('actress_id', a.id);

const totalCount = count ?? 0;
const totalPages = Math.ceil(totalCount / PER_PAGE);

const { data: rows } = await supabase
  .from('product_actresses')
  .select('products ( id, dmm_content_id, title, image_url_small, review_average, review_count, price_min, price_text )')
  .eq('actress_id', a.id)
  .range(offset, offset + PER_PAGE - 1);

type ProductRow = { id: string; dmm_content_id: string; title: string; image_url_small: string | null; review_average: number | null; review_count: number | null; price_min: number | null; price_text: string | null };
const products: ProductRow[] = ((rows ?? []) as any[]).map((r: any) => r.products).filter(Boolean);

// 共演女優
const { data: relationsRaw } = await supabase
  .from('actress_relations')
  .select('actress_b_id, co_appearances, actresses!actress_relations_actress_b_id_fkey ( name, slug, image_url_small )')
  .eq('actress_a_id', a.id)
  .order('co_appearances', { ascending: false })
  .limit(6);

type RelatedActress = { name: string; slug: string; image_url_small: string | null; co_appearances: number };
const relatedActresses: RelatedActress[] = ((relationsRaw ?? []) as any[]).map((r: any) => ({
  ...r.actresses,
  co_appearances: r.co_appearances,
})).filter(Boolean);

const { count: likeCount } = await supabase
  .from('likes').select('*', { count: 'exact', head: true })
  .eq('target_type', 'actress').eq('target_id', a.id);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: a.name,
  image: a.image_url_large ?? a.image_url_small ?? undefined,
  url: `https://ntr-douga.com/actress/${slug}`,
};
---

<BaseLayout
  title={`${a.name}の出演作品一覧${page > 1 ? ` (${page}ページ目)` : ''} | NTR動画ナビ`}
  description={`${a.name}の人妻・NTR動画${totalCount}本を紹介。レビュー評価・価格・関連女優情報つき。`}
  ogImage={a.image_url_large ?? a.image_url_small ?? undefined}
  canonical={`https://ntr-douga.com/actress/${slug}${page > 1 ? `?page=${page}` : ''}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {page > 1 && <link rel="prev" href={`https://ntr-douga.com/actress/${slug}${page === 2 ? '' : `?page=${page - 1}`}`} />}
    {page < totalPages && <link rel="next" href={`https://ntr-douga.com/actress/${slug}?page=${page + 1}`} />}
  </Fragment>

  <Header showBack />

  <main style="max-width:1024px;margin:0 auto;padding:0 0 100px;">

    <!-- Profile Hero -->
    <div style="background:#111;border-bottom:1px solid #2a2a2a;padding:24px 16px;">
      <div style="display:flex;gap:16px;align-items:flex-start;">
        <div style="width:80px;height:80px;border-radius:50%;border:2px solid #d4a843;overflow:hidden;flex-shrink:0;background:#1a1a1a;">
          {a.image_url_large
            ? <img src={a.image_url_large} alt={a.name} style="width:100%;height:100%;object-fit:cover;" />
            : <img src={a.image_url_small ?? ''} alt={a.name} style="width:100%;height:100%;object-fit:cover;" />
          }
        </div>
        <div style="flex:1;">
          <h1 style="font-size:22px;font-weight:700;margin-bottom:4px;">{a.name}</h1>
          {a.ruby && <p style="font-size:13px;color:#888;margin-bottom:8px;">{a.ruby}</p>}
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            {a.bust && <span style="background:#1a1a1a;border:1px solid #2a2a2a;font-size:11px;padding:3px 8px;border-radius:4px;">B{a.bust}{a.cup}</span>}
            {a.waist && <span style="background:#1a1a1a;border:1px solid #2a2a2a;font-size:11px;padding:3px 8px;border-radius:4px;">W{a.waist}</span>}
            {a.hip && <span style="background:#1a1a1a;border:1px solid #2a2a2a;font-size:11px;padding:3px 8px;border-radius:4px;">H{a.hip}</span>}
            {a.height && <span style="background:#1a1a1a;border:1px solid #2a2a2a;font-size:11px;padding:3px 8px;border-radius:4px;">{a.height}cm</span>}
          </div>
        </div>
      </div>
    </div>

    <div style="padding:16px;">

      <!-- Like -->
      <div style="margin-bottom:20px;">
        <LikeButton targetType="actress" targetId={a.id} initialCount={likeCount ?? 0} />
      </div>

      <!-- Related Actresses -->
      {relatedActresses.length > 0 && (
        <div style="margin-bottom:20px;">
          <div style="font-size:15px;font-weight:700;margin-bottom:10px;">共演女優</div>
          <div style="display:flex;gap:12px;overflow-x:auto;scrollbar-width:none;padding-bottom:4px;">
            {relatedActresses.map(a => (
              <a href={`/actress/${a.slug}`} style="flex-shrink:0;width:72px;text-align:center;text-decoration:none;color:inherit;">
                <div style="width:56px;height:56px;border-radius:50%;background:#1a1a1a;border:1px solid #2a2a2a;margin:0 auto 4px;overflow:hidden;display:flex;align-items:center;justify-content:center;">
                  {a.image_url_small
                    ? <img src={a.image_url_small} alt={a.name} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                    : <svg width="24" height="24" fill="none" stroke="#555" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  }
                </div>
                <div style="font-size:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{a.name}</div>
                <div style="font-size:10px;color:#888;">{a.co_appearances}本</div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Works -->
      <div style="font-size:15px;font-weight:700;margin-bottom:10px;">出演作品 <span style="color:#888;font-weight:400;font-size:13px;">{totalCount}本</span></div>

      {products.length > 0 ? (
        <>
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
            {products.map(p => (
              <a href={`/item/${p.dmm_content_id}`} style="display:flex;align-items:center;gap:12px;background:#111;border:1px solid #2a2a2a;border-radius:12px;padding:12px;text-decoration:none;color:inherit;">
                <div style="width:64px;height:90px;border-radius:6px;overflow:hidden;flex-shrink:0;background:#1a1a1a;">
                  {p.image_url_small && <img src={p.image_url_small} alt={p.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />}
                </div>
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13px;font-weight:600;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{p.title}</div>
                  <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
                    {p.review_average != null && p.review_average > 0 && <span style="color:#d4a843;font-size:13px;font-weight:600;">★ {Number(p.review_average).toFixed(1)}</span>}
                    {p.review_count != null && p.review_count > 0 && <span style="font-size:12px;color:#888;">({p.review_count})</span>}
                    {(p.price_text || p.price_min) && <span style="font-size:13px;font-weight:600;margin-left:auto;">{p.price_text ?? `¥${p.price_min!.toLocaleString()}〜`}</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>

          {totalPages > 1 && (
            <div style="display:flex;justify-content:center;align-items:center;gap:8px;padding:16px 0;">
              {page > 1 && (
                <a href={`/actress/${slug}${page === 2 ? '' : `?page=${page - 1}`}`} style="padding:8px 16px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:13px;">← 前へ</a>
              )}
              <span style="font-size:13px;color:#888;">{page} / {totalPages}</span>
              {page < totalPages && (
                <a href={`/actress/${slug}?page=${page + 1}`} style="padding:8px 16px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:13px;">次へ →</a>
              )}
            </div>
          )}
        </>
      ) : (
        <div style="text-align:center;padding:40px 0;color:#888;">作品情報を準備中です</div>
      )}

    </div>
  </main>

  <BottomNav active="actress" />
</BaseLayout>

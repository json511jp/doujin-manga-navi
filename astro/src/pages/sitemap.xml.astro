---
import { supabase } from '../lib/supabase';

// Content-Type を XML として返す
if (Astro.response) {
  Astro.response.headers.set('Content-Type', 'application/xml; charset=utf-8');
}

const SITE = 'https://ntr-douga.com';
const today = new Date().toISOString().split('T')[0];

function urlEntry(path: string, lastmod: string | null | undefined, changefreq = 'weekly', priority = '0.5') {
  const lastmodTag = lastmod ? `<lastmod>${lastmod}</lastmod>` : '';
  return `<url><loc>${SITE}${path}</loc>${lastmodTag}<changefreq>${changefreq}</changefreq><priority>${priority}</priority></url>`;
}

function toDate(value: string | null | undefined): string | null {
  if (!value) return null;
  return value.split('T')[0];
}

// 静的ページ（/explore/* /graph は noindex のため除外）
const staticEntries = [
  urlEntry('/', today, 'daily', '1.0'),
  urlEntry('/ranking/monthly', today, 'daily', '0.9'),
  urlEntry('/ranking/weekly', today, 'daily', '0.9'),
  urlEntry('/ranking/ntr', today, 'weekly', '0.8'),
  urlEntry('/actress', today, 'weekly', '0.7'),
];

// 作品ページ
const { data: products } = await supabase
  .from('products')
  .select('dmm_content_id, updated_at')
  .eq('is_active', true)
  .order('updated_at', { ascending: false })
  .limit(5000);

type ProductSitemap = { dmm_content_id: string; updated_at: string | null };
const productEntries = ((products ?? []) as unknown as ProductSitemap[]).map(p =>
  urlEntry(`/item/${p.dmm_content_id}`, toDate(p.updated_at), 'monthly', '0.8')
);

// タグページ
const { data: genres } = await supabase
  .from('genres')
  .select('slug')
  .limit(500);

type GenreSitemap = { slug: string };
const tagEntries = ((genres ?? []) as unknown as GenreSitemap[]).map(g =>
  urlEntry(`/tag/${g.slug}`, today, 'weekly', '0.7')
);

// 女優ページ
const { data: actresses } = await supabase
  .from('actresses')
  .select('slug, updated_at')
  .order('updated_at', { ascending: false })
  .limit(2000);

type ActressSitemap = { slug: string; updated_at: string | null };
const actressEntries = ((actresses ?? []) as unknown as ActressSitemap[]).map(a =>
  urlEntry(`/actress/${a.slug}`, toDate(a.updated_at), 'monthly', '0.6')
);

const allEntries = [...staticEntries, ...productEntries, ...tagEntries, ...actressEntries];
---
<?xml version="1.0" encoding="UTF-8"?><urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" set:html={allEntries.join('')}></urlset>

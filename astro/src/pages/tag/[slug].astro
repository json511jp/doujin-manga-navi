---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BottomNav from '../../components/BottomNav.astro';
import ProductCard from '../../components/ProductCard.astro';
import { siteConfig } from '../../../../site.config.js';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;
const PER_PAGE = 24;
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1'));
const offset = (page - 1) * PER_PAGE;

const { data: genre } = await supabase
  .from('genres')
  .select('id, name, slug')
  .eq('slug', slug!)
  .single();

if (!genre) return Astro.redirect('/404');
type GenreRow = { id: string; name: string; slug: string };
const g = genre as unknown as GenreRow;

// 件数取得
const { count } = await supabase
  .from('product_genres')
  .select('*', { count: 'exact', head: true })
  .eq('genre_id', g.id);

const totalCount = count ?? 0;
const totalPages = Math.ceil(totalCount / PER_PAGE);

// 作品取得
const { data: rows } = await supabase
  .from('product_genres')
  .select('products ( id, dmm_content_id, title, image_url_small, review_average, review_count, price_min, price_text )')
  .eq('genre_id', g.id)
  .order('created_at', { referencedTable: 'products', ascending: false })
  .range(offset, offset + PER_PAGE - 1);

type ProductRow = { id: string; dmm_content_id: string; title: string; image_url_small: string | null; review_average: number | null; review_count: number | null; price_min: number | null; price_text: string | null };
const products: ProductRow[] = ((rows ?? []) as any[]).map((r: any) => r.products).filter(Boolean);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'TOP', item: `${siteConfig.siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: g.name },
  ],
};
---

<BaseLayout
  title={`【${new Date().getFullYear()}年最新】${g.name} おすすめ作品${totalCount > 0 ? `${totalCount}選` : '一覧'} | ${siteConfig.siteName}`}
  description={totalCount > 0 ? `${g.name}の人気動画${totalCount}本を厳選。レビュー評価・価格・出演者情報つきで徹底紹介。` : `${g.name}ジャンルの動画を紹介。レビュー評価・価格・出演者情報つきで徹底紹介。`}
  canonical={`${siteConfig.siteUrl}/tag/${slug}${page > 1 ? `?page=${page}` : ''}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {page > 1 && <link rel="prev" href={`https://ntr-douga.com/tag/${slug}${page === 2 ? '' : `?page=${page - 1}`}`} />}
    {page < totalPages && <link rel="next" href={`https://ntr-douga.com/tag/${slug}?page=${page + 1}`} />}
  </Fragment>

  <Header />

  <nav style="padding:10px 16px;font-size:12px;color:#555;max-width:1024px;margin:0 auto;">
    <a href="/" style="color:#555;text-decoration:none;">TOP</a>
    <span style="margin:0 6px;">›</span>
    <span style="color:#888;">{g.name}</span>
  </nav>

  <main style="max-width:1024px;margin:0 auto;padding:0 16px 100px;">

    <h1 style="font-size:20px;font-weight:700;margin-bottom:4px;">
      【{new Date().getFullYear()}年最新】{g.name} おすすめ作品
    </h1>
    <p style="font-size:13px;color:#888;margin-bottom:20px;">{totalCount}本</p>

    {products.length > 0 ? (
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:32px;">
        {products.map(p => (
          <a href={`/item/${p.dmm_content_id}`} style="display:flex;align-items:center;gap:12px;background:#111;border:1px solid #2a2a2a;border-radius:12px;padding:12px;text-decoration:none;color:inherit;">
            <div style="width:64px;height:90px;border-radius:6px;overflow:hidden;flex-shrink:0;background:#1a1a1a;">
              {p.image_url_small && <img src={p.image_url_small} alt={p.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />}
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;font-weight:600;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{p.title}</div>
              <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
                {p.review_average != null && p.review_average > 0 && <span style="color:#d4a843;font-size:13px;font-weight:600;">★ {Number(p.review_average).toFixed(1)}</span>}
                {p.review_count != null && p.review_count > 0 && <span style="font-size:12px;color:#888;">({p.review_count})</span>}
                {(p.price_text || p.price_min) && <span style="font-size:13px;font-weight:600;margin-left:auto;">{p.price_text ?? `¥${p.price_min!.toLocaleString()}〜`}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="text-align:center;padding:60px 0;color:#888;">
        <p style="font-size:15px;">このジャンルの作品はまだありません</p>
        <a href="/" style="display:inline-block;margin-top:16px;color:#d4a843;text-decoration:none;font-size:14px;">TOPに戻る</a>
      </div>
    )}

    {totalPages > 1 && (
      <div style="display:flex;justify-content:center;align-items:center;gap:8px;padding:16px 0;">
        {page > 1 && (
          <a href={`/tag/${slug}${page === 2 ? '' : `?page=${page - 1}`}`} style="padding:8px 16px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:13px;">← 前へ</a>
        )}
        <span style="font-size:13px;color:#888;">{page} / {totalPages}</span>
        {page < totalPages && (
          <a href={`/tag/${slug}?page=${page + 1}`} style="padding:8px 16px;border:1px solid #2a2a2a;border-radius:8px;color:#888;text-decoration:none;font-size:13px;">次へ →</a>
        )}
      </div>
    )}

  </main>

  <BottomNav />
</BaseLayout>

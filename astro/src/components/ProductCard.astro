---
interface Props {
  contentId: string;
  title: string;
  imageUrl?: string | null;
  reviewAverage?: number | null;
  reviewCount?: number;
  priceMin?: number | null;
  priceText?: string | null;
  actressName?: string | null;
  isNew?: boolean;
}

const { contentId, title, imageUrl, reviewAverage, reviewCount, priceMin, priceText, actressName, isNew } = Astro.props;
const stars = reviewAverage ? reviewAverage.toFixed(1) : null;
const price = priceText ?? (priceMin ? `¥${priceMin.toLocaleString()}〜` : null);
---

<a
  href={`/item/${contentId}`}
  style="display:block;background:#111;border:1px solid #2a2a2a;border-radius:12px;overflow:hidden;text-decoration:none;color:inherit;transition:transform 0.2s,box-shadow 0.2s;"
  onmouseover="this.style.transform='scale(1.02)';this.style.boxShadow='0 0 0 1px rgba(212,168,67,0.4)'"
  onmouseout="this.style.transform='';this.style.boxShadow=''"
>
  <div style="aspect-ratio:2/3;position:relative;overflow:hidden;background:#1a1a1a;">
    {imageUrl
      ? <img src={imageUrl} alt={title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
      : <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a1a1a,#2a2a2a);"></div>
    }
    <div style="position:absolute;bottom:0;left:0;right:0;height:60%;background:linear-gradient(to top,rgba(0,0,0,0.9),transparent);"></div>
    {isNew && (
      <div style="position:absolute;top:8px;right:8px;background:#d4a843;color:#000;font-size:10px;font-weight:700;padding:2px 6px;border-radius:3px;">NEW</div>
    )}
  </div>
  <div style="padding:10px;">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
      {stars && <span style="color:#d4a843;font-size:12px;font-weight:600;">★ {stars}</span>}
      {reviewCount && <span style="font-size:11px;color:#888;">({reviewCount})</span>}
      {price && <span style="font-size:13px;font-weight:600;margin-left:auto;">{price}</span>}
    </div>
    <div style="font-size:12px;font-weight:600;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{title}</div>
    {Astro.locals.siteSettings.features.actresses && actressName && <div style="font-size:11px;color:#888;margin-top:4px;">{actressName}</div>}
  </div>
</a>
